# For local development only (no phone scanning)
# The tracking URL is determined automatically based on window.location.hostname:
#   - localhost/127.0.0.1 → http://localhost:3000/track/:id
#   - any other hostname → https://www.stiqr.top/track/:id
#
# For local development with network access (phone scanning on same Wi-Fi),
# uncomment the line below and replace with your computer's IP address:
# VITE_BACKEND_URL=http://192.168.1.111:3000
